# hal-speaker configuration
# Copy to .env and fill in your values

# Device name (shows in logs)
DEVICE_NAME=hal-speaker

# Wake word model name (matches .onnx file in models/ dir, or built-in openWakeWord model)
WAKE_WORD=hey_hal
WAKE_WORD_THRESHOLD=0.5

# Audio device indices (run `python3 -m sounddevice` to list)
# Leave blank to use system default
INPUT_DEVICE=
OUTPUT_DEVICE=

# Some USB mics reject 16000 Hz directly. Try 44100 or 48000 if you get
# PortAudio / invalid sample rate errors during startup.
SAMPLE_RATE=16000

# Test mode: bypass wake word and use Enter-to-talk instead.
# Great for first bring-up and debugging.
TEST_MODE=false

# Whisper model: tiny.en, base.en, small.en, medium.en
# base.en is a good balance of speed and accuracy on a mini PC
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu

# OpenClaw gateway URL (on this same machine or your Hal VM)
OPENCLAW_URL=http://localhost:9999
OPENCLAW_CHANNEL=voice
OPENCLAW_SESSION_KEY=
OPENCLAW_AUTH_TOKEN=

# Relay timeout (seconds to wait for Hal's response)
RELAY_TIMEOUT=30

# TTS provider: edge | elevenlabs | pyttsx3
TTS_PROVIDER=edge

# Edge TTS settings
# Run `python3 -m edge_tts --list-voices | grep en-US` to see options
TTS_VOICE=en-US-GuyNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# ElevenLabs settings
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
