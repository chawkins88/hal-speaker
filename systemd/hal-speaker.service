[Unit]
Description=Hal Smart Speaker Voice Relay
After=network.target sound.target

[Service]
Type=simple
User=hal
WorkingDirectory=/opt/hal-speaker
ExecStart=/opt/hal-speaker/.venv/bin/python3 src/main.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
